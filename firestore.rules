rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function sameOrg(orgId) {
      return signedIn() && userDoc().data.organizationId == orgId;
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /organizations/{orgId} {
      allow read, write: if sameOrg(orgId);
    }

    match /{collectionName}/{docId} {
      allow read: if collectionName in ['agents', 'agentRuns', 'memories', 'tools', 'usageLogs']
        && sameOrg(resource.data.organizationId);
      allow create: if collectionName in ['agents', 'agentRuns', 'memories', 'tools', 'usageLogs']
        && sameOrg(request.resource.data.organizationId);
      allow update: if collectionName in ['agents', 'agentRuns', 'memories', 'tools', 'usageLogs']
        && sameOrg(request.resource.data.organizationId);
      allow delete: if collectionName in ['agents', 'agentRuns', 'memories', 'tools', 'usageLogs']
        && sameOrg(resource.data.organizationId);
    }
  }
}
